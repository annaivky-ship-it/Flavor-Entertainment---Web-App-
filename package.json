{
  "name": "flavn-2026--booking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode live",
    "dev:demo": "vite --config vite.config.demo.ts --mode demo",
    "build": "tsc --noEmit && vite build --mode live",
    "build:demo": "vite build --config vite.config.demo.ts --mode demo",
    "preview": "vite preview",
    "preview:demo": "vite preview --config vite.config.demo.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "seed": "npx tsx scripts/seedFirestore.ts",
    "functions:build": "cd functions && npm run build",
    "functions:deploy": "firebase deploy --only functions",
    "deploy:live": "npm run build && firebase deploy --only hosting",
    "deploy:demo": "npm run build:demo && firebase deploy --only hosting:demo",
    "deploy": "npm run build && firebase deploy"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "firebase": "^12.9.0",
    "lucide-react": "0.417.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
