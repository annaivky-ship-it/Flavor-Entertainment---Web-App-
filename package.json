{
  "name": "flavn-2026--booking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode demo",
    "build:production": "tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "functions:build": "cd functions && npm run build",
    "functions:deploy": "firebase deploy --only functions",
    "deploy": "npm run build:production && firebase deploy --only hosting:production",
    "deploy:demo": "npm run build:demo && firebase deploy --only hosting:demo",
    "deploy:production": "npm run build:production && firebase deploy --only hosting:production",
    "deploy:all": "npm run build:production && firebase deploy --only hosting:production && npm run build:demo && firebase deploy --only hosting:demo"
  },
  "dependencies": {
    "@sentry/react": "^10.44.0",
    "@tailwindcss/vite": "^4.2.1",
    "firebase": "^12.9.0",
    "lucide-react": "0.417.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "lightningcss": "^1.29.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
