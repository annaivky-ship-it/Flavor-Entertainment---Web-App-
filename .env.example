# App Mode: "demo" for mock data site, "production" for live Firebase site
VITE_APP_MODE=production

# Firebase Web SDK Configuration
# REQUIRED in any non-demo build. The app throws at boot in production if any
# of these are missing. The web API key is intentionally public; the security
# boundary is Firestore/Storage Security Rules + Cloud Function auth + App Check
# (see services/firebaseClient.ts and docs/deployment-checklist.md).
# Current production project: studio-4495412314-3b1ce
VITE_FIREBASE_API_KEY=AIzaSyDJXlPBCyGfFkHwYLb_fw-lyJ1CJRpQLz8
VITE_FIREBASE_AUTH_DOMAIN=studio-4495412314-3b1ce.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=studio-4495412314-3b1ce
VITE_FIREBASE_STORAGE_BUCKET=studio-4495412314-3b1ce.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=387015361731
VITE_FIREBASE_APP_ID=1:387015361731:web:1f9bf616548947cc3a4e76

# PayID Configuration
# REQUIRED in production builds — the app throws at boot if either is missing.
# In development, missing values trigger a red banner on the deposit modal so
# the placeholders can't accidentally ship to real customers.
# Set these in the hosting environment (Vercel) for Production / Preview / Development.
VITE_PAY_ID_NAME=
VITE_PAY_ID_EMAIL=

# Payment mode — 'manual' (admin confirms in dashboard) or 'monoova' (auto-confirm via webhook).
# Use 'manual' until Monoova is provisioned.
VITE_PAYMENT_MODE=manual

