# Firebase Configuration
# Required for the application to connect to Firebase services.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# PayID Configuration
# Used for simulated PayID payments
VITE_PAY_ID_NAME=
VITE_PAY_ID_EMAIL=

# =============================================================================
# Cloud Functions environment (set via `firebase functions:config:set`, NOT .env)
# Shown here for documentation purposes only.
# =============================================================================

# DNS + OTP hashing pepper — MUST match across all environments.
# Set with: firebase functions:config:set dns.hash_pepper="<random-256-bit-hex>"
# Accessed in functions as: process.env.DNS_HASH_PEPPER
# DNS_HASH_PEPPER=

# Twilio SMS (required for OTP delivery in production)
# Set with:
#   firebase functions:config:set twilio.sid="ACxxxxxx" twilio.token="xxxxx" twilio.sms_from="+61400000000"
# Accessed via functions.config().twilio.*
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=

# Dev/test: set MESSAGING_DRY_RUN=true to skip actual SMS sending.
# firebase functions:config:set messaging.dry_run="true"
# MESSAGING_DRY_RUN=true

