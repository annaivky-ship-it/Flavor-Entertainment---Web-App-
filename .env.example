# =============================================================================
# Flavor Entertainers - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the frontend.

# -----------------------------------------------------------------------------
# App Mode: "demo" for mock data, "production" for live Firebase
# -----------------------------------------------------------------------------
VITE_APP_MODE=production

# -----------------------------------------------------------------------------
# Firebase Configuration (required when VITE_APP_MODE=production)
# Get these from Firebase Console > Project Settings > Your Apps
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# PayID Configuration (required for payment flow)
# The PayID details shown to clients for deposit payments
# -----------------------------------------------------------------------------
VITE_PAY_ID_NAME=
VITE_PAY_ID_EMAIL=

# -----------------------------------------------------------------------------
# Error Tracking (optional)
# Get a DSN from https://sentry.io
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=

# =============================================================================
# Cloud Functions Environment Variables
# Set these via: firebase functions:secrets:set <KEY>
# Or in .env files within the functions/ directory
# =============================================================================

# -----------------------------------------------------------------------------
# Twilio (SMS & WhatsApp notifications)
# Get credentials from https://console.twilio.com
# -----------------------------------------------------------------------------
# TWILIO_SID=                  # Account SID
# TWILIO_TOKEN=                # Auth Token
# TWILIO_WHATSAPP_FROM=        # WhatsApp sender (e.g., whatsapp:+14155238886)
# TWILIO_SMS_FROM=             # SMS sender phone number
# TWILIO_ACCOUNT_SID=          # Same as TWILIO_SID (used by messaging provider)
# TWILIO_AUTH_TOKEN=           # Same as TWILIO_TOKEN (used by messaging provider)
# TWILIO_FROM_NUMBER=          # Same as TWILIO_SMS_FROM (used by messaging provider)

# -----------------------------------------------------------------------------
# ClickSend (alternative SMS provider)
# Get credentials from https://www.clicksend.com
# -----------------------------------------------------------------------------
# CLICKSEND_USERNAME=
# CLICKSEND_API_KEY=

# -----------------------------------------------------------------------------
# MessageMedia (alternative SMS provider)
# Get credentials from https://www.messagemedia.com
# -----------------------------------------------------------------------------
# MESSAGEMEDIA_API_KEY=
# MESSAGEMEDIA_API_SECRET=

# -----------------------------------------------------------------------------
# Didit KYC (identity verification)
# Get credentials from https://didit.me
# -----------------------------------------------------------------------------
# DIDIT_API_KEY=               # API key for creating verification sessions
# DIDIT_WORKFLOW_ID=           # Workflow ID for the verification flow
# DIDIT_API_BASE=              # API base URL (default: https://verification.didit.me)
# DIDIT_APP_URL=               # Your app URL for callbacks (e.g., https://flavorentertainers.com.au)
# DIDIT_WEBHOOK_SECRET=        # Secret for verifying webhook signatures

# -----------------------------------------------------------------------------
# Google Gemini AI (risk analysis)
# Get an API key from https://ai.google.dev
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# DNS_HASH_PEPPER=             # Secret pepper for hashing client data in DNS register
#                              # Generate with: openssl rand -hex 32

# -----------------------------------------------------------------------------
# Messaging Configuration
# -----------------------------------------------------------------------------
# MESSAGING_DRY_RUN=true       # Set to "true" to log messages instead of sending
