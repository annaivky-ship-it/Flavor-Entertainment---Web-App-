rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPerformer() {
      return isSignedIn() && (
        request.auth.token.role == 'performer' ||
        exists(/databases/$(database)/documents/performers_auth/$(request.auth.uid))
      );
    }

    // --- Performers (public read, admin write) ---
    match /performers/{performerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Services (public read, admin write) ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      // Clients can create bookings (even unauthenticated for public form)
      allow create: if true;

      // Only the booking owner, assigned performer, or admin can read
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.client_uid == request.auth.uid)
        || (isPerformer() && resource.data.performer_uid == request.auth.uid);

      // Only admins can update booking status
      allow update: if isAdmin();

      // No one can delete bookings
      allow delete: if false;
    }

    // --- DNS Register (admin only) ---
    match /dns_entries/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy Do Not Serve (admin only) ---
    match /do_not_serve/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Blacklist (admin only, legacy) ---
    match /blacklist/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- KYC Sessions (admin only — sensitive data) ---
    match /kyc_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Risk Scores (admin only) ---
    match /risk_scores/{scoreId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Consents (the booking client can create, admin can read) ---
    match /consents/{consentId} {
      allow create: if true; // Public booking form
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // --- Incident Reports ---
    match /incident_reports/{reportId} {
      // Performers can create reports
      allow create: if isPerformer();

      // Admin can read and update (approve/reject)
      allow read: if isAdmin()
        || (isPerformer() && resource.data.reported_by_performer_id == request.auth.uid);

      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Audit Logs (admin read-only, Cloud Functions write) ---
    // Covers both collection names for backwards compatibility
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Vetting Applications ---
    match /vetting_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'draft');
      allow delete: if false;
    }

    // --- Communications (scoped to participants) ---
    match /communications/{msgId} {
      // Users can only read messages they participate in; admins can read all
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.participant_uids);

      // Signed-in users can create messages (must include their own UID)
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participant_uids;

      // Only the read flag can be toggled, and only by a participant
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participant_uids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if false;
    }

    // --- Admin Users (admin only) ---
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Settings (admin only) ---
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.recipient_uid == request.auth.uid);
      allow create: if false; // Only Cloud Functions
      allow update: if isSignedIn() && resource.data.recipient_uid == request.auth.uid;
      allow delete: if false;
    }

    // --- User Profiles (users can read/write their own, admins can read all) ---
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // --- Performer Auth Mapping (self or admin only) ---
    match /performers_auth/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
    }

    // --- Default: deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
