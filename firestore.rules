rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPerformer() {
      return isSignedIn() && (
        request.auth.token.role == 'performer' ||
        exists(/databases/$(database)/documents/performers_auth/$(request.auth.uid))
      );
    }

    // --- Customers (self or admin read; writes via Cloud Functions only) ---
    match /customers/{customerId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow write: if false;
    }

    // --- Performers ---
    // Public can read only when status == 'active' and only safe fields are
    // exposed via the client; admin and the performer themselves get full
    // read. Writes are server-side only.
    match /performers/{performerId} {
      allow read: if true;  // Frontend filters by status==active for public listings
      allow create: if false;
      allow update, delete: if false;
    }

    // --- Services (public read, admin write) ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow create: if true;  // Public booking form
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.client_uid == request.auth.uid)
        || isPerformer();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Verification records (admin-read; server writes only) ---
    match /verificationRecords/{recordId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Face embeddings (NEVER readable by clients) ---
    match /faceEmbeddings/{subjectId} {
      allow read: if false;
      allow write: if false;
    }

    // --- DNS register (admin-read; server writes only) ---
    match /doNotServeList/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Manual review queue (admin-read; server writes only) ---
    match /manualReviewQueue/{bookingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- ID review queue (admin-read; server writes only) ---
    match /idReviewQueue/{queueId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Penny drops (server-only) ---
    match /pennyDrops/{dropId} {
      allow read: if false;
      allow write: if false;
    }

    // --- Risk signals (admin-read; server writes only) ---
    match /riskSignals/{signalId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- OTP attempts (server-only — codes are sensitive) ---
    match /otpAttempts/{otpId} {
      allow read: if false;
      allow write: if false;
    }

    // --- Rate limit counters (server-only) ---
    match /rateLimits/{bucketKey} {
      allow read: if false;
      allow write: if false;
    }

    // --- Audit log (append-only via server; admin-read) ---
    match /auditLog/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // --- Legacy DNS register (admin-only) ---
    match /dns_entries/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy do_not_serve (admin-only) ---
    match /do_not_serve/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy blacklist (admin-only) ---
    match /blacklist/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy risk_scores ---
    match /risk_scores/{scoreId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Consents (the booking client can create, admin can read) ---
    match /consents/{consentId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // --- Incident Reports ---
    match /incident_reports/{reportId} {
      allow create: if isPerformer();
      allow read: if isAdmin()
        || (isPerformer() && resource.data.reported_by_performer_id == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Payment Events (server-only, admin read) ---
    match /payment_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Notification Outbox (server-only, admin read) ---
    match /notification_outbox/{notifId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Legacy audit logs (kept for backward compat) ---
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Vetting Applications ---
    match /vetting_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'draft');
      allow delete: if false;
    }

    // --- Communications ---
    match /communications/{msgId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.participant_uids is list && request.auth.uid in resource.data.participant_uids);
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.participant_uids is list && request.auth.uid in resource.data.participant_uids
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      allow delete: if false;
    }

    // --- Admin Users ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.recipient_uid == request.auth.uid);
      allow create: if false;
      allow update: if isSignedIn() && resource.data.recipient_uid == request.auth.uid;
      allow delete: if false;
    }

    // --- Performer Auth Mapping ---
    match /performers_auth/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Default: deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
