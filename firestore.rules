rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPerformer() {
      return isSignedIn() && (
        request.auth.token.role == 'performer' ||
        exists(/databases/$(database)/documents/performers_auth/$(request.auth.uid))
      );
    }

    function isValidBookingCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['client_name', 'client_email', 'client_phone', 'status'])
        && data.client_name is string && data.client_name.size() > 0 && data.client_name.size() <= 200
        && data.client_email is string && data.client_email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$')
        && data.client_phone is string && data.client_phone.size() >= 8 && data.client_phone.size() <= 20
        && data.status in ['pending_performer_acceptance', 'PENDING'];
    }

    // --- Performers (public read, admin write) ---
    match /performers/{performerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Services (public read, admin write) ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      // Clients can create bookings via Cloud Functions (preferred) or public form
      // Validates required fields and restricts initial status
      allow create: if isValidBookingCreate();

      // Only the booking owner or admin can read
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.client_uid == request.auth.uid)
        || (isPerformer() && resource.data.performer_uid == request.auth.uid);

      // Only admins can update booking status
      allow update: if isAdmin();

      // No one can delete bookings
      allow delete: if false;
    }

    // --- DNS Register (admin only) ---
    match /dns_entries/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy Do Not Serve (admin only) ---
    match /do_not_serve/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Blacklist (admin only, legacy) ---
    match /blacklist/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- KYC Sessions (admin only — sensitive data) ---
    match /kyc_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Risk Scores (admin only) ---
    match /risk_scores/{scoreId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Consents ---
    match /consents/{consentId} {
      // Require at least a booking_id and consent_text for valid consent
      allow create: if request.resource.data.keys().hasAll(['booking_id', 'consent_text'])
        && request.resource.data.booking_id is string
        && request.resource.data.consent_text is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // --- Incident Reports ---
    match /incident_reports/{reportId} {
      // Performers can create reports
      allow create: if isPerformer();

      // Admin can read and update (approve/reject)
      allow read: if isAdmin()
        || (isPerformer() && resource.data.reported_by_performer_id == request.auth.uid);

      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Audit Logs (admin read-only, system write) ---
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Vetting Applications ---
    match /vetting_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'draft');
      allow delete: if false;
    }

    // --- Communications ---
    match /communications/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      allow delete: if false;
    }

    // --- Admin Users ---
    match /admins/{adminId} {
      allow read: if isAdmin() || isOwner(adminId);
      allow write: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.recipient_uid == request.auth.uid);
      allow create: if false; // Only Cloud Functions
      allow update: if isSignedIn() && resource.data.recipient_uid == request.auth.uid;
      allow delete: if false;
    }

    // --- Performer Auth Mapping ---
    match /performers_auth/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
    }

    // --- Booking Slots (system-managed, admin readable) ---
    match /booking_slots/{slotId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Idempotency Keys (system only) ---
    match /idempotency_keys/{keyId} {
      allow read, write: if false; // Only Cloud Functions
    }

    // --- Message Logs (admin read-only) ---
    match /message_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // --- Notification Queue (system only) ---
    match /notificationsQueue/{queueId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // --- Default: deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
