rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
         request.auth.token.admin == true);
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPerformer() {
      return isSignedIn() && request.auth.token.role == 'performer';
    }

    // Vetting Applications
    match /vetting_applications/{appId} {
      // Users can read/create their own applications
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Only admins can update status and review fields
      // Users can only update draft applications they own
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        resource.data.status == 'draft' &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewedAt', 'reviewedBy', 'riskFlags', 'decisionReason'])
      );
      
      allow delete: if isAdmin();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK bypasses rules — Cloud Functions only
    }

    // KYC Records
    match /kyc_records/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if false; // Only updated via Cloud Functions / Webhooks
      
      match /dvs_checks/{checkId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow write: if false; // Only updated via Cloud Functions
      }
    }

    // Message Logs
    match /message_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only updated via Cloud Functions
    }

    // Settings
    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
    }

    // Performers
    match /performers/{performerId} {
      allow read: if true; // Public gallery
      allow write: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || 
                  (isSignedIn() && resource.data.client_email == request.auth.token.email) ||
                  (isPerformer() && resource.data.performer_id == request.auth.token.performerId);
      allow update: if isAdmin() || 
                    (isPerformer() && resource.data.performer_id == request.auth.token.performerId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
                    (isSignedIn() && resource.data.client_email == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deposit_receipt_path', 'status']));
      allow delete: if isAdmin();
    }

    // Do Not Serve
    match /do_not_serve/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Communications
    match /communications/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || 
                  (isSignedIn() && (resource.data.sender == request.auth.token.email || resource.data.recipient == request.auth.token.email || resource.data.sender == request.auth.token.name || resource.data.recipient == request.auth.token.name || resource.data.recipient == request.auth.token.performerId || resource.data.sender == request.auth.token.performerId));
      allow update, delete: if isAdmin();
    }

    // Blacklist
    match /blacklist/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Notifications Queue
    match /notificationsQueue/{id} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // Verified Clients — managed exclusively by Cloud Functions (Admin SDK bypasses rules).
    // Client browsers must never read or write this collection directly.
    // Admins can read for support tooling; revocation is done via revokeVerifiedClient callable.
    match /verified_clients/{emailHash} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions (Admin SDK) only
    }

    // OTP Sessions — extremely sensitive; contains hashed OTP codes and verified flags.
    // No direct client access permitted under any circumstance.
    match /otp_sessions/{sessionId} {
      allow read, write: if false; // Cloud Functions (Admin SDK) only
    }

    // DNS entries (duplicated here from DNS_WORKFLOW.md for the active rules file)
    match /dns_entries/{dnsId} {
      allow read, write: if isAdmin();
    }

    // Audit log for DNS / booking events (singular — used by functions/src/dns/index.ts)
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }
  }
}