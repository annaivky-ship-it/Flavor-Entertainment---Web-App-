rules_version = '2';

// ============================================================
// Firestore Security Rules — Flavor Entertainers
// Last audited: 2026-03-19
// ============================================================
//
// Collection Access Summary:
//
//   performers        — Public read (catalogue browsing), admin write only
//   services          — Public read, admin write only
//   bookings          — Authenticated create (validated), owner/performer/admin read, admin update, no delete
//   dns_entries       — Admin only (read/write)
//   do_not_serve      — Admin only (read/write)
//   blacklist         — Admin only (read/write, legacy)
//   blocklist         — Cloud Functions only (no client access)
//   kyc_sessions      — Admin read, Cloud Functions write only
//   risk_scores       — Admin read, Cloud Functions write only
//   consents          — Authenticated create (validated), admin read, no update/delete
//   incident_reports  — Performer create, performer/admin read, admin update, no delete
//   audit_log         — Admin read/create, no update/delete
//   vetting_applications — Authenticated create, owner/admin read, owner (draft only)/admin update
//   communications    — Participant/admin read, authenticated create (validated), participant update (read status only)
//   admins            — Admin/owner read, admin write
//   settings          — Authenticated read, admin write
//   notifications     — Owner/admin read, owner update, Cloud Functions create only
//   performers_auth   — Owner/admin read, admin write
//   booking_slots     — Admin read, Cloud Functions write only
//   rate_limits       — Cloud Functions only (no client access)
//   idempotency_keys  — Cloud Functions only (no client access)
//   message_logs      — Admin read, Cloud Functions write only
//   notificationsQueue — Admin read, Cloud Functions write only
//
// Default: deny all reads and writes for unlisted collections
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPerformer() {
      return isSignedIn() && (
        request.auth.token.role == 'performer' ||
        exists(/databases/$(database)/documents/performers_auth/$(request.auth.uid))
      );
    }

    function isValidBookingCreate() {
      let data = request.resource.data;
      return isSignedIn()
        && data.keys().hasAll(['client_name', 'client_email', 'client_phone', 'status'])
        && data.client_name is string && data.client_name.size() > 0 && data.client_name.size() <= 200
        && data.client_email is string && data.client_email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$')
        && data.client_phone is string && data.client_phone.size() >= 8 && data.client_phone.size() <= 20
        && data.status in ['pending_performer_acceptance', 'PENDING'];
    }

    // --- Performers (public read for catalogue, admin write) ---
    match /performers/{performerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Services (public read, admin write) ---
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      // Authenticated users can create bookings with validated fields
      // Unauthenticated booking creation must go through Cloud Functions
      allow create: if isValidBookingCreate();

      // Only the booking owner, admin, or the assigned performer can read
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.client_uid == request.auth.uid)
        || (isPerformer() && resource.data.performer_id == request.auth.uid);

      // Only admins can update booking status
      allow update: if isAdmin();

      // No one can delete bookings
      allow delete: if false;
    }

    // --- DNS Register (admin only) ---
    match /dns_entries/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Legacy Do Not Serve (admin only) ---
    match /do_not_serve/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Blacklist (admin only, legacy) ---
    match /blacklist/{entryId} {
      allow read, write: if isAdmin();
    }

    // --- Blocklist (Cloud Functions only) ---
    match /blocklist/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- KYC Sessions (admin only — sensitive data) ---
    match /kyc_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Risk Scores (admin only) ---
    match /risk_scores/{scoreId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Consents ---
    match /consents/{consentId} {
      // Authenticated users can record consent with required fields
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['booking_id', 'consent_text'])
        && request.resource.data.booking_id is string
        && request.resource.data.consent_text is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // --- Incident Reports ---
    match /incident_reports/{reportId} {
      // Performers can create reports
      allow create: if isPerformer();

      // Admin can read and update (approve/reject)
      allow read: if isAdmin()
        || (isPerformer() && resource.data.reported_by_performer_id == request.auth.uid);

      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Audit Logs (admin read/create, no update/delete) ---
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // --- Vetting Applications ---
    match /vetting_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'draft');
      allow delete: if false;
    }

    // --- Communications ---
    // Access scoped to booking participants via denormalized participant_uids array.
    match /communications/{msgId} {
      // Only participants of the conversation or admins can read
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.participant_uids);

      // Creator must be authenticated, sender_uid must match to prevent impersonation
      allow create: if isSignedIn()
        && request.resource.data.sender_uid == request.auth.uid
        && request.auth.uid in request.resource.data.participant_uids
        && request.resource.data.keys().hasAll(['booking_id', 'sender_uid', 'participant_uids', 'message']);

      // Only allow marking as read
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participant_uids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if false;
    }

    // --- Admin Users ---
    match /admins/{adminId} {
      allow read: if isAdmin() || isOwner(adminId);
      allow write: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.recipient_uid == request.auth.uid);
      allow create: if false; // Only Cloud Functions
      allow update: if isSignedIn() && resource.data.recipient_uid == request.auth.uid;
      allow delete: if false;
    }

    // --- Performer Auth Mapping ---
    match /performers_auth/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin();
    }

    // --- Booking Slots (system-managed, admin readable) ---
    match /booking_slots/{slotId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions write
    }

    // --- Rate Limits (Cloud Functions only — no client access) ---
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // --- Idempotency Keys (Cloud Functions only) ---
    match /idempotency_keys/{keyId} {
      allow read, write: if false;
    }

    // --- Message Logs (admin read-only) ---
    match /message_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // --- Notification Queue (Cloud Functions only) ---
    match /notificationsQueue/{queueId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // --- Default: deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
