# ──────────────────────────────────────────────────────────────
# LIVE PRODUCTION ENVIRONMENT — Flavor Entertainers
# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
#
# Used by: npm run dev  |  npm run build  |  npm run deploy:live
# ──────────────────────────────────────────────────────────────

VITE_APP_MODE=live

# ── Firebase ────────────────────────────────────────────────────
# Find these in Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ── PayID ────────────────────────────────────────────────────────
# Your business PayID details shown on deposit instructions
VITE_PAY_ID_NAME=Flavor Entertainers
VITE_PAY_ID_EMAIL=payments@flavorentertainers.com.au

# ── Cloud Functions environment vars (set via Firebase CLI, NOT here) ─────
# Run: firebase functions:config:set twilio.account_sid="..." etc.
# These are server-side only — never expose in VITE_ vars.
#
# Required Cloud Function config:
#   twilio.account_sid
#   twilio.auth_token
#   twilio.whatsapp_from           (e.g. whatsapp:+61400000000)
#   twilio.sms_from                (e.g. +61400000000)
#   gemini.api_key
#   dns.hash_pepper                (random 32+ char string for HMAC hashing)
#   payid.reference_prefix         (e.g. FLV-)
