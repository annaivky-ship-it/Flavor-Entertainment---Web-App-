rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.admin == true);
    }

    function isAllowedKycType() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp)|application/pdf');
    }

    function isAllowedPhotoType() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function withinSize(maxBytes) {
      return request.resource != null && request.resource.size < maxBytes;
    }

    // --- studio-4495412314-3b1ce-id-uploads ---
    // Performer ID images. Direct client access is forbidden — uploads happen
    // via 15-minute signed PUT URLs (see performerRequestIdUploadUrl), reads
    // happen via 5-minute signed READ URLs (see adminGetIdImageReviewUrl).
    // Cloud Functions delete objects after admin review. The bucket also has
    // a lifecycle rule (1-day TTL on pending-review/*) as a backstop.
    match /b/studio-4495412314-3b1ce-id-uploads/o/{allPaths=**} {
      allow read, write: if false;
    }

    // --- Customer KYC vetting uploads ---
    // Owner-scoped uploads with type + size enforcement. Reads admin-only.
    match /vetting/{uid}/{appId}/{fileName} {
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && isAllowedKycType()
        && withinSize(10 * 1024 * 1024);
      allow update: if false;
      allow delete: if false;
      allow read: if isAdmin();
    }

    // --- Performer public assets (portfolio photos / video intros) ---
    // Read public (used in marketing gallery). Writes admin-only and
    // require image content type + 5MB cap.
    match /performers/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && isAllowedPhotoType()
        && withinSize(5 * 1024 * 1024);
      allow delete: if isAdmin();
    }

    // --- Legacy ID upload path (kept for backward compat; no new uploads) ---
    match /ids/{allPaths=**} {
      allow write: if false;
      allow read: if isAdmin();
    }

    // --- Default deny ---
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
